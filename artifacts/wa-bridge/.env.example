# ============================================================
# WA-BRIDGE — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_OWNER_ID=your_telegram_user_id
TELEGRAM_OWNER_USERNAME=your_username
TELEGRAM_ADMIN_GROUP_ID=-100xxxxxxxxxx      # Group for support routing
TELEGRAM_SPONSOR_CHANNEL=@your_channel      # Force-join gatekeeping channel

# --- Redis (BullMQ backbone) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Workspace ---
WORKSPACE_ROOT=./workspaces                 # Per-user sandbox root
MAX_SESSIONS_PER_USER=5                     # Unlimited with owner override

# --- WhatsApp Defaults ---
WA_BROWSER_NAME=Chrome
WA_DEVICE_SYNC_TIMEOUT=60000
WA_AUTO_JOIN_GROUPS=                        # CSV of WA group JIDs to auto-join new sessions

# --- Rate Limits ---
ALLSTATUS_MIN_DELAY_MS=4000                 # Min delay between allstatus sends
ALLSTATUS_MAX_DELAY_MS=9000                 # Max delay (jitter upper bound)
JOIN_DELAY_MS=3500                          # Delay between bulk join ops
LEAVE_DELAY_MS=2000                         # Delay between bulk leave ops
CIRCUIT_BREAKER_THRESHOLD=5                 # Consecutive errors before open
CIRCUIT_BREAKER_RESET_MS=3600000           # 1 hour auto-pause

# --- Pairing ---
PAIRING_CODE_PREFIX=pappy-bot              # Pairing code prefix

# --- Logging ---
LOG_LEVEL=info                              # error|warn|info|debug
LOG_DIR=./logs

# --- Maintenance ---
MAINTENANCE_MODE=false
